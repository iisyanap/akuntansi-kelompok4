# ══════════════════════════════════════════════════════════════════════════
#  AccSys — Environment Variables
#  Copy this file to .env and fill in the values:
#    cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com/project/<your-project>/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── Flask ─────────────────────────────────────────────────────────────────
# Generate a strong random string, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET_KEY=change-this-to-a-random-string

# ── Groq AI (optional — can also be entered via the AI Assistant UI) ────
# Get a free key from: https://console.groq.com/keys
GROQ_API_KEY=
